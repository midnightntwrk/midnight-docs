# Copy this file to `.env` and fill in real values where needed.
# `.env` is gitignored.

# Algolia DocSearch — required for config validation, even locally.
# Use placeholder strings to boot the dev server; ask a teammate for real
# values if you need search to actually work.
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_KEY=

# Typesense search (optional — used by the typesense search theme).
TYPESENSE_SEARCH_API_KEY=
TYPESENSE_HOST=
TYPESENSE_COLLECTION_NAME=midnight-docs

# PostHog analytics (optional).
POSTHOG_API_KEY=
POSTHOG_API_HOST=
POSTHOG_PROJECT_ID=

# Google Tag Manager (optional). When set, gtag is enabled in the classic preset.
GOOGLE_TAG_MANAGER_ID=
